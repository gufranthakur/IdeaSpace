// In your class fields
private Viewport topBarViewport;
private Viewport leftViewport;
private Viewport rightViewport;

// In your create() or initialization method
public void create() {
    int screenWidth = Gdx.graphics.getWidth();
    int screenHeight = Gdx.graphics.getHeight();

    // Define your top bar height
    int topBarHeight = 80; // adjust as needed
    int contentHeight = screenHeight - topBarHeight;

    // Top bar viewport (full width, top of screen)
    topBarViewport = new ScreenViewport();
    topBarViewport.setScreenBounds(0, contentHeight, screenWidth, topBarHeight);

    // Left viewport for slides (half width, below top bar)
    leftViewport = new ScreenViewport();
    leftViewport.setScreenBounds(0, 0, screenWidth / 2, contentHeight);

    // Right viewport for 3D space (half width, below top bar)
    rightViewport = new ScreenViewport();
    rightViewport.setScreenBounds(screenWidth / 2, 0, screenWidth / 2, contentHeight);

    // Set viewports to your stages
    topBarScreen.getStage().setViewport(topBarViewport);
    slidesScreen.getStage().setViewport(leftViewport);
}

@Override
public void render() {
    float deltaTime = Gdx.graphics.getDeltaTime();

    space.render(deltaTime);

    Gdx.gl.glClear(GL20.GL_COLOR_BUFFER_BIT | GL20.GL_DEPTH_BUFFER_BIT);

    if (!lectureFlag) {
        homeScreen.render(deltaTime);
    } else {
        // Render top bar
        topBarViewport.apply();
        topBarScreen.render(deltaTime);

        // Render left slides
        leftViewport.apply();
        slidesScreen.render(deltaTime);

        // Render right 3D space
        rightViewport.apply();
        space.getSceneManager().update(deltaTime);
        space.getSceneManager().render();
    }
}

@Override
public void resize(int width, int height) {
    int topBarHeight = 80;
    int contentHeight = height - topBarHeight;

    topBarViewport.setScreenBounds(0, contentHeight, width, topBarHeight);
    topBarViewport.update(width, topBarHeight, true);

    leftViewport.setScreenBounds(0, 0, width / 2, contentHeight);
    leftViewport.update(width / 2, contentHeight, true);

    rightViewport.setScreenBounds(width / 2, 0, width / 2, contentHeight);
    rightViewport.update(width / 2, contentHeight, true);
}
